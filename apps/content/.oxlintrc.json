{
  "plugins": ["react", "nextjs", "jsdoc"],
  "settings": {
    "next": {
      "rootDir": "."
    }
  },
  "rules": {
    "nextjs/no-img-element": "warn",
    "nextjs/no-typos": "warn",
    "jsdoc/require-param": ["warn", { "exemptedBy": ["inheritdoc", "jsx", "api"] }],
    "jsdoc/require-param-description": "warn",
    "jsdoc/require-returns": ["warn", { "exemptedBy": ["inheritdoc", "jsx", "api"] }],
    "jsdoc/check-tag-names": [
      "warn",
      { "definedTags": ["remarks", "jsx", "jsxImportSource", "api"] }
    ]
  },
  "ignorePatterns": ["src/libs/shadcn/**"]
}
